{
  "profiles": {
    "Client": {
      "commandName": "Executable",
      "executablePath": "dotnet",
      "commandLineArgs": "\"$(VINTAGE_STORY_LOCAL)/Vintagestory.dll\" --tracelog --addModPath \"$(ProjectDir)/bin/$(Configuration)/Mods\" --addOrigin \"$(ProjectDir)/assets\" --dataPath=\"$(VINTAGE_STORY_DATA_LOCAL)\"",
      "workingDirectory": "$(VINTAGE_STORY_LOCAL)"
    },
    "Server": {
      "commandName": "Executable",
      "executablePath": "dotnet",
      "commandLineArgs": "\"$(VINTAGE_STORY_LOCAL)/VintagestoryServer.dll\" --tracelog --addModPath \"$(ProjectDir)/bin/$(Configuration)/Mods\" --addOrigin \"$(ProjectDir)/assets\" --dataPath=\"$(VINTAGE_STORY_DATA_LOCAL)\"",
      "workingDirectory": "$(VINTAGE_STORY_LOCAL)"
    }
  }
}